---
const voteApi = import.meta.env.PUBLIC_VOTE_API ?? ''
---
<script type="application/json" id="crowd-api" set:html={JSON.stringify(voteApi)} />
<script>
  // Runs on first load and after every ClientRouter navigation back to a page
  // with a crowd column. Fetches live standings and fills the cells.
  function loadCrowd() {
    const apiEl = document.getElementById('crowd-api')
    if (!apiEl || !document.querySelector('[data-crowd]')) return // no crowd column here
    const api = JSON.parse(apiEl.textContent!) as string
    if (!api) return
    const ctrl = new AbortController()
    const timer = setTimeout(() => ctrl.abort(), 4000)
    fetch(`${api}/api/standings`, { signal: ctrl.signal })
      .then((r) => r.json())
      .then((data: { standings: { model: string; rating: number }[] }) => {
        clearTimeout(timer)
        for (const s of data.standings) {
          const cell = document.querySelector(`[data-crowd="${CSS.escape(s.model)}"]`)
          if (cell) cell.textContent = String(s.rating)
        }
      })
      .catch(() => {/* column stays "—" — the crowd is asleep */})
  }
  document.addEventListener('astro:page-load', loadCrowd)
</script>
